AUTH_ENABLED=true
JWT_SECRET=change-me-in-real-environments

# Token lifetimes used to sign JWTs.
# Examples: 15m, 30m, 7d, 10s
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Cookie maxAge values in milliseconds.
# Keep them aligned with the token lifetimes above.
ACCESS_TOKEN_COOKIE_MAX_AGE_MS=900000
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=604800000

# Cookie policy.
# In local development with the Angular proxy, '/' is the most robust option.
AUTH_COOKIE_PATH=/

# Typical values: lax, strict, none
# If you use none, browsers require AUTH_COOKIE_SECURE=true.
AUTH_COOKIE_SAME_SITE=lax

# false for local http://localhost, true for real HTTPS environments.
AUTH_COOKIE_SECURE=false

API_DELAY_ENABLED=true
API_DELAY_MIN_MS=200
API_DELAY_MAX_MS=900
