  "info": {
    "title": "NTT Demo Vehicle Catalog API",
    "description": "Backend API for the NTT Angular practice: authentication, vehicle catalog, brands, models, pagination and role-based access.\n\nRecommended flow in Swagger: call `POST /auth/login`, then use `GET /auth/me` and the protected endpoints normally. When the short-lived access cookie expires, call `POST /auth/refresh` and retry the failed request. Use `POST /auth/logout` to close the session cleanly.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "refresh_token"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Account email address",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "description": "Account password",
            "example": "admin123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserProfileDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique user identifier",
            "example": "1"
          },
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "admin@example.com"
          },
          "name": {
            "type": "string",
            "description": "Display name associated with the account",
            "example": "Admin User"
          },
          "role": {
            "type": "string",
            "description": "Role assigned to the account. ADMIN can create, update and delete vehicles. USER has read-only access.",
            "enum": [
              "ADMIN",
              "USER"
            ],
            "example": "ADMIN"
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "role"
        ]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "description": "Profile of the authenticated user whose access and refresh cookies were issued",
            "allOf": [
              {
                "$ref": "#/components/schemas/UserProfileDto"
              }
            ]
          }
        },
        "required": [
          "user"
        ]
      },
      "PaginatedMetaDto": {
        "type": "object",
        "properties": {
          "totalItems": {
            "type": "number",
            "description": "Total number of records matching the current query",
            "example": 50
          },
          "itemCount": {
            "type": "number",
            "description": "Number of records returned in the current page",
            "example": 10
          },
          "itemsPerPage": {
            "type": "number",
            "description": "Maximum records per page requested by the client",
            "example": 10
          },
          "totalPages": {
            "type": "number",
            "description": "Total number of pages for the current query and limit",
            "example": 5
          },
          "currentPage": {
            "type": "number",
            "description": "Current page number (1-indexed)",
            "example": 1
          },
          "hasNextPage": {
            "type": "boolean",
            "description": "Indicates whether another page exists after the current one",
            "example": true
          },
          "hasPreviousPage": {
            "type": "boolean",
            "description": "Indicates whether a page exists before the current one",
            "example": false
          }
        },
        "required": [
          "totalItems",
          "itemCount",
          "itemsPerPage",
          "totalPages",
          "currentPage",
          "hasNextPage",
          "hasPreviousPage"
        ]
      },
      "PaginatedResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "description": "Collection of records returned for the current page",
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "meta": {
            "description": "Pagination metadata for the current query",
            "allOf": [
              {
                "$ref": "#/components/schemas/PaginatedMetaDto"
              }
            ]
          }
        },
        "required": [
          "items",
          "meta"
        ]
      },
      "CarBrandSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Resolved brand identifier",
            "example": "brand-1"
          },
          "name": {
            "type": "string",
            "description": "Resolved brand display name",
            "example": "Toyota"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "CarModelSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Resolved model identifier",
            "example": "model-1"
          },
          "name": {
            "type": "string",
            "description": "Resolved model display name",
            "example": "Corolla"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "CarSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Vehicle identifier"
          },
          "brand": {
            "description": "Resolved brand information for read operations",
            "allOf": [
              {
                "$ref": "#/components/schemas/CarBrandSummary"
              }
            ]
          },
          "model": {
            "description": "Resolved model information for read operations",
